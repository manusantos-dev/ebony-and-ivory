rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // UTILS: Core Authentication Checks
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // SOCIAL: User Profiles
    match /users/{userId} {
      allow read: if true; // Public profiles are visible to anyone
      allow write: if isOwner(userId); // Only the user can edit their bio/links
    }

    // CORE: Scores & Manuscripts
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isAuth();
      // Only the author can modify or delete their score
      allow update, delete: if isAuth() && resource.data.publisherUid == request.auth.uid;
    }

    // SOCIAL GRAPH: Follows & Relationships
    match /relationships/{relId} {
      allow read: if isAuth();
      // User can only initiate a follow if they are the 'follower'
      allow create: if isAuth() && request.resource.data.followerId == request.auth.uid;
      allow update: if isAuth() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid);
      allow delete: if isAuth() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid);
    }

    // SOCIAL: Notifications
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isOwner(resource.data.targetUid);
      // Anyone logged in can trigger a notification (e.g., liking a post)
      allow create: if isAuth();
      allow update, delete: if isOwner(resource.data.targetUid);
    }
  }
}
