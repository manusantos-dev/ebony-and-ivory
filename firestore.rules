rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -- Auth Helpers --
    function isAuthenticated() { return request.auth != null; }
    function isOwner(uid) { return isAuthenticated() && request.auth.uid == uid; }
    // FIX: Simplified admin check to avoid nested token lookups that might fail
    function isAdmin() { return isAuthenticated() && request.auth.token.email == "jm.santos.dev@gmail.com"; }

    // -- Schema Validation --
    function isValidScore() {
      let payload = request.resource.data;
      return payload.keys().hasAll(['bpm', 'composer', 'id', 'keySig', 'measures', 'createdAt']) &&
             payload.bpm is number && payload.bpm > 0 && payload.bpm <= 300 &&
             payload.composer is string && payload.composer.size() >= 0 && payload.composer.size() <= 100 &&
             payload.id is string && payload.id.size() <= 64 &&
             payload.keySig is string && payload.keySig.size() <= 10 &&
             payload.measures is list && payload.measures.size() <= 500;
    }

    // -- Access Rules --
    match /users/{userId}/scores/{scoreId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidScore();
      allow delete: if isOwner(userId);
    }

    match /public_scores/{scoreId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.publisherUid == request.auth.uid && isValidScore();
      allow update: if isAuthenticated() && resource.data.get('publisherUid', '') == request.auth.uid && isValidScore();
      // FIX: Reordered logic to check admin status first and safely fallback to owner check
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get('publisherUid', '') == request.auth.uid);
    }
  }
}
